menu "Example Configuration"

    config SPEAKER_BOOT_VOICE_PROMPTS
        bool "Enable boot voice prompts (server_connected, mic_open, mic_close)"
        default n
        help
            When enabled, the server_connected, mic_open, and mic_close audio
            prompts will play during agent lifecycle events.
            The boot.mp3 will always play regardless of this setting.

    config SPEAKER_AGENT_AUTOSTART
        bool "Enable voice agent auto-start on boot"
        default n
        help
            When enabled, the Coze agent will automatically initialize and
            connect to the server on boot.
            When disabled, the agent must be started manually.

    menu "Default WiFi Profiles"
        help
            Configure WiFi networks for auto-connect on boot.
            Networks are tried in order (AP1 first, then AP2, etc.).
            Leave SSID empty to skip a profile.

        config SPEAKER_WIFI_AP1_SSID
            string "AP1 SSID"
            default ""
        config SPEAKER_WIFI_AP1_PASSWORD
            string "AP1 Password"
            default ""

        config SPEAKER_WIFI_AP2_SSID
            string "AP2 SSID"
            default ""
        config SPEAKER_WIFI_AP2_PASSWORD
            string "AP2 Password"
            default ""

        config SPEAKER_WIFI_AP3_SSID
            string "AP3 SSID"
            default ""
        config SPEAKER_WIFI_AP3_PASSWORD
            string "AP3 Password"
            default ""
    endmenu

    config SPEAKER_WAKE_WORD_ENABLE
        bool "Enable wake word detection and touch button wake-up"
        default n
        help
            When enabled, WakeNet detection is active and the touch button
            can trigger wake-up.
            When disabled, no wake word detection or touch wake-up.

    menuconfig EXAMPLE_COZE_AGENT_ENABLE_DEFAULT_CONFIG
        bool "Default coze agent config"
        default n

    if EXAMPLE_COZE_AGENT_ENABLE_DEFAULT_CONFIG

        config EXAMPLE_COZE_AGENT_APP_ID
            string "App ID"
            default "110049xxxxxxx"

        config EXAMPLE_COZE_AGENT_PUBLIC_KEY
            string "Public key"
            default "lsKjtB67xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

        config EXAMPLE_COZE_AGENT_PRIVATE_KEY_FILE_PATH
            string "Private key"
            default "./private_key.pem"

        config EXAMPLE_COZE_AGENT_CUSTOM_CONSUMER
            string "Custom consumer (Optional)"
            default ""

        menuconfig EXAMPLE_COZE_AGENT_BOT1_ENABLE
            bool "Bot 1"
            default y

        if EXAMPLE_COZE_AGENT_BOT1_ENABLE
            config EXAMPLE_COZE_AGENT_BOT1_NAME
                string "Bot name"
                default "Lin Jia Nv Hai"

            config EXAMPLE_COZE_AGENT_BOT1_ID
                string "Bot ID"
                default "7516538xxxxxxxxxxxx"

            config EXAMPLE_COZE_AGENT_BOT1_DESCRIPTION
                string "Bot description"
                default "A warm-voiced female AI character who listens to the user's thoughts and offers comforting responses."

            config EXAMPLE_COZE_AGENT_BOT1_VOICE_ID
                string "Bot voice ID"
                default "7426720361733144585"
        endif

        menuconfig EXAMPLE_COZE_AGENT_BOT2_ENABLE
            bool "Bot 2"
            default y

        if EXAMPLE_COZE_AGENT_BOT2_ENABLE
            config EXAMPLE_COZE_AGENT_BOT2_NAME
                string "Bot name"
                default "Wan Qu Da Shu"

            config EXAMPLE_COZE_AGENT_BOT2_ID
                string "Bot ID"
                default "7516538xxxxxxxxxxxx"

            config EXAMPLE_COZE_AGENT_BOT2_DESCRIPTION
                string "Bot description"
                default "A male AI character with a regional accent. He responds quickly and concisely, but does not perform actions on behalf of the user."

            config EXAMPLE_COZE_AGENT_BOT2_VOICE_ID
                string "Bot voice ID"
                default "7426720361732915209"
        endif
    endif

endmenu
