# WiFi credentials
CONFIG_MEETING_WIFI_SSID="your_wifi_ssid"
CONFIG_MEETING_WIFI_PASSWORD="your_wifi_password"

# Business server (ip:port, no scheme, e.g. 192.168.1.100:8080)
CONFIG_AIGENT_SERVER_HOST="192.168.1.100:8080"

# Volcengine RTC App ID (used in Authorization header)
CONFIG_RTC_APPID="your_rtc_app_id"
